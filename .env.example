# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Database ───────────────────────────────────────────────────────────────
# Your PostgreSQL connection string from your hosting provider
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── CORS ───────────────────────────────────────────────────────────────────
# The exact URL of your frontend app (no trailing slash)
FRONTEND_URL=https://your-frontend.vercel.app
